old_project_cols <- setdiff(names(old_projects_clean), "ContactId")
merged_all <- merged_df |>
left_join(old_projects_clean, by = "ContactId")
# 8. Merge: + old_projects via ContactId
# Først omdøb SMVContactId → ContactId
old_projects_clean <- old_projects |>
rename(contactId = SMVContactId)
# Gem kolonnenavne til senere brug (undtagen dem vi vil fjerne)
old_project_cols <- setdiff(names(old_projects_clean), "ContactId")
merged_all <- merged_df |>
left_join(old_projects_clean, by = "contactId")
# 9. Fjern unødvendige kolonner fra old_projects
merged_all <- merged_all |>
select(-Id, -SMVCompanyId, -SharedWith)
# 10. Behold kun én række pr. produktionsenhed (PNumber)
merged_unique <- merged_all |>
distinct(PNumber, .keep_all = TRUE)
View(merged_all)
merged_df <- merged_df |>
select(-ends_with(".y"))
# 9. Fjern unødvendige kolonner fra old_projects
merged_all <- merged_all |>
select(-Id, -SMVCompanyId, -SharedWith)
# 10. Behold kun én række pr. produktionsenhed (PNumber)
merged_unique <- merged_all |>
distinct(PNumber, .keep_all = TRUE)
