# DEL 1: Merge af datasæt – sammenfletning af alle relevante tabeller
# -------------------------------------------------------------------------
library(dplyr)
library(stringr)
library(tidyr)
#indlæser data
meetings <- readRDS("data/meetings.rds")
events <- readRDS("data/events.rds")
event_participants <- readRDS("data/event_participants.rds")
company_contacts <- readRDS("data/company_contacts.rds")
all_contact <- readRDS("data/all_contact.rds")
all_companies <- readRDS("data/all_companies.rds")
old_projects <- readRDS("data/old_projects.rds")
# 1. Merge: all_companies + company_contacts via CompanyId
merged_df <- all_companies |>
left_join(company_contacts, by = "CompanyId") |>
select(-ends_with(".y"), -ends_with(".x"))
# 2. Merge: + kontaktoplysninger fra all_contact via contactId
merged_df <- merged_df |>
left_join(all_contact, by = "contactId") |>
select(-ends_with(".y"), -ends_with(".x"))
# 3. Merge: + mødedata (først fjern dubletter per virksomhed)
meetings_unique <- meetings |>
group_by(CompanyId) |>
summarise(across(everything(), first), .groups = "drop")
merged_df <- merged_df |>
left_join(meetings_unique, by = "CompanyId") |>
select(-ends_with(".y"), -ends_with(".x"))
# 4. Omdøb CVR-nummer-kolonne til 'Cvr' for ensartethed
merged_df <- merged_df |>
rename(Cvr = `z_companies_1_CVR-nummer_1`)
# 5. Merge: + events via Cvr
events_unique <- events |>
group_by(Cvr) |>
summarise(across(everything(), first), .groups = "drop")
merged_df <- merged_df |>
left_join(events_unique, by = "Cvr") |>
select(-ends_with(".y"), -ends_with(".x"))
# 6. Merge: + event_participants via Cvr
event_participants_unique <- event_participants |>
group_by(Cvr) |>
summarise(across(everything(), first), .groups = "drop")
merged_df <- merged_df |>
left_join(event_participants_unique, by = "Cvr")
# # 7. Omdøb kolonner for læsevenlighed og standardisering
# colnames(merged_df) <- c(
#   "BusinessCouncilMember", "CompanyDateStamp", "CompanyId", "CompanyType",
#   "CVR", "Employees", "PostalCode", "CompanyTypeName", "PNumber", "Country",
#   "NACECode", "CompanyStatus", "AdvertisingProtected", "ContactId",
#   "CompanyOwnerId", "ContactLastUpdated", "TitleChanged", "LocationChanged",
#   "CreatedBy", "MeetingLength", "Firstname", "UserRole", "Initials",
#   "EventExternalId", "EventPublicId", "Description", "LocationId",
#   "MaxParticipants", "EventLength", "EventId"
# )
# 8. Merge: + old_projects via ContactId
# Først omdøb SMVContactId → ContactId
old_projects_clean <- old_projects |>
rename(contactId = SMVContactId)
# Gem kolonnenavne til senere brug (undtagen dem vi vil fjerne)
old_project_cols <- setdiff(names(old_projects_clean), "ContactId")
merged_all <- merged_df |>
left_join(old_projects_clean, by = "contactId")
merged_df <- merged_df |>
select(-ends_with(".y"))
# 9. Fjern unødvendige kolonner fra old_projects
merged_all <- merged_all |>
select(-Id, -SMVCompanyId, -SharedWith)
# 10. Behold kun én række pr. produktionsenhed (PNumber)
merged_unique <- merged_all |>
distinct(PNumber, .keep_all = TRUE)
View(merged_all)
